{
  "name": "omp-context-mode",
  "version": "0.1.0",
  "type": "module",
  "description": "context-mode integration for oh-my-pi (OMP) — saves up to 98% of context window via sandboxed execution and session continuity",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "omp": {
    "extensions": ["dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "oh-my-pi",
    "omp",
    "context-mode",
    "mcp",
    "extension",
    "ai",
    "coding-agent"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
