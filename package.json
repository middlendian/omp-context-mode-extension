{
  "name": "@middlendian/omp-context-mode-extension",
  "version": "0.1.0",
  "type": "module",
  "description": "context-mode integration for oh-my-pi (OMP) — saves up to 98% of context window via sandboxed execution and session continuity",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "omp": {
    "extensions": ["dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "oh-my-pi",
    "omp",
    "context-mode",
    "mcp",
    "extension",
    "ai",
    "coding-agent"
  ],
  "peerDependencies": {
    "context-mode": "1.0.15"
  },
  "peerDependenciesMeta": {
    "context-mode": {
      "optional": false
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
